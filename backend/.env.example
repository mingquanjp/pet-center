PORT=8080
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
JWT_SECRET=replace-with-secret
JWT_EXPIRES_IN_SECONDS=86400
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret
CLOUDINARY_UPLOAD_FOLDER=pet-center

VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_TMN_CODE=replace-with-vnpay-tmn-code
VNPAY_HASH_SECRET=replace-with-vnpay-hash-secret
VNPAY_RETURN_URL=https://replace-with-backend-domain/api/v1/payments/vnpay/return
VNPAY_IPN_URL=https://replace-with-backend-domain/api/v1/payments/vnpay/ipn
VNPAY_PAYMENT_EXPIRE_MINUTES=15
VNPAY_DEBUG_LOG=false
FRONTEND_BASE_URL=https://replace-with-frontend-domain
